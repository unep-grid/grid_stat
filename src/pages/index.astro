---
import MainLayout from '../layouts/MainLayout.astro';
import '@/styles/global.css'

import { latestNews } from "../data/mockData";

interface Props {
  title?: string;
}

const { title = 'GRID Stat Portal' } = Astro.props;
const base = import.meta.env.BASE_URL
---

<MainLayout>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Welcome to the  {title}
      </h1>
      <p class="text-xl text-gray-600">
        Explore currated data from more that 120 sources.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-gray-900 mb-6">Latest Updates</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestNews.map(news => (
          <article class="bg-white rounded-lg shadow-sm p-6">
            <h3 class="text-lg font-semibold mb-2">
              <a href={base} class="text-blue-600 hover:text-blue-800">
                {news.title}
              </a>
            </h3>
            <p class="text-gray-600 mb-4">{news.excerpt}</p>
            <time class="text-sm text-gray-500">{news.date}</time>
          </article>
        ))}
      </div>
    </section>
  </div>
</MainLayout>
