---
import MainLayout from "../layouts/MainLayout.astro";
import "@/styles/global.css";

const teamMembers = [
  {
    name: "Ferdinand Moser",
    role: "Principal Investigator",
    description:
      "Leading the research on global emissions patterns and their impact on climate systems.",
      imageUrl: "/user_placeholder/user1.png", 
    email: "f.moser@griddata.org",
  },
  {
    name: "Franz Moser",
    role: "Data Science Lead",
    description:
      "Specializing in machine learning applications for climate data analysis.",
    imageUrl: "/user_placeholder/user2.png",
    email: "franz.moser@griddata.org",
  },
  {
    name: "Frédéric Moser",
    role: "Environmental Policy Advisor",
    description:
      "Bridging the gap between scientific findings and policy implementations.",
    imageUrl: "/user_placeholder/user3.png",
    email: "frederic.m@griddata.org",
  },
  {
    name: "Filipe Moser",
    role: "Technical Lead",
    description:
      "Managing our data infrastructure and visualization platforms.",
    imageUrl: "/user_placeholder/user4.png",
    email: "f.moser.tech@griddata.org",
  },
];

const milestones = [
  {
    year: 2020,
    title: "Project Inception",
    description:
      "GRID DATA was established to address the growing need for accessible climate data.",
  },
  {
    year: 2021,
    title: "First Data Release",
    description:
      "Launch of our comprehensive GHG emissions database covering 193 countries.",
  },
  {
    year: 2022,
    title: "International Recognition",
    description:
      "Featured in major climate research publications and policy papers.",
  },
  {
    year: 2023,
    title: "Platform Enhancement",
    description:
      "Released our new interactive dashboard for emissions visualization.",
  },
];
---

<MainLayout
  title="About GRID DATA"
  description="Learn about our mission to make global emissions data accessible and actionable"
  pubDate={new Date()}
  heroImage="/blog-placeholder-about.jpg"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">About GRID DATA</h1>
      <div class="prose prose-lg text-gray-600 max-w-none">
        <p class="mb-4">
          At GRID DATA, we believe that accessible and accurate environmental
          data is crucial for informed decision-making in the fight against
          climate change. Our team of dedicated researchers and data scientists
          works tirelessly to collect, analyze, and visualize greenhouse gas
          emissions data from around the world.
        </p>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-4xl font-bold mb-12">Our Team</h2>
      <div class="space-y-6">
        {
          teamMembers.map((member) => (
            <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex flex-col md:flex-row md:items-start md:space-x-8">
                <img
                  src={member.imageUrl}
                  alt={member.name}
                  class="w-48 h-48 object-cover rounded-lg mb-4 md:mb-0"
                />
                <div class="flex-1">
                  <h3 class="text-2xl font-bold mb-2">{member.name}</h3>
                  <p class="text-blue-600 mb-4">{member.role}</p>
                  <p class="text-gray-600 mb-4">{member.description}</p>
                  <a
                    href={`mailto:${member.email}`}
                    class="text-blue-600 hover:text-blue-800"
                  >
                    {member.email}
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Our Journey</h2>
      <div class="space-y-12">
        {
          milestones.map((milestone) => (
            <div class="flex gap-8">
              <div class="flex-shrink-0 w-24">
                <span class="text-2xl font-bold text-blue-600">
                  {milestone.year}
                </span>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">
                  {milestone.title}
                </h3>
                <p class="text-gray-600">{milestone.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Contact Us</h2>
      <div class="bg-gray-50 rounded-lg p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">
              Get in Touch
            </h3>
            <p class="text-gray-600 mb-4">
              Have questions about our data or interested in collaboration? We'd
              love to hear from you.
            </p>
            <a
              href="mailto:contact@griddata.org"
              class="inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700"
            >
              Email Us
            </a>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Location</h3>
            <p class="text-gray-600">
              GRID DATA Institute<br />
              Climate Research Campus<br />
              1234 Environmental Way<br />
              Genève, Switzerland
            </p>
          </div>
        </div>
      </div>
    </section>
  </div></MainLayout
>
